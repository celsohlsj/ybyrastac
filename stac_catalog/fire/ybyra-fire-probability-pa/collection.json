{
  "type": "Collection",
  "stac_version": "1.0.0",
  "id": "ybyra-fire-probability-pa",
  "title": "Fire Probability — Pará (Random Forest model)",
  "description": "Annual fire probability map for the state of Pará, Brazil, derived from a Random Forest classification model trained on ERA5-Land climate variables, land use/land cover (MapBiomas), MODIS/VIIRS ignition data (2002–2023), and landscape metrics. AUC-ROC = 0.933. Resolution 1 km, EPSG:4674. Formally delivered as Nota Técnica to SEMAS-PA. Values: continuous probability [0–1] expressed as uint16 scaled by 10000.",
  "license": "CC-BY-4.0",
  "keywords": ["fire probability", "Pará", "Brazil", "Random Forest", "SEMAS-PA", "fire ecology", "ignition"],
  "providers": [
    { "name": "IPAM / UFMA",  "roles": ["producer","processor"], "url": "https://ipam.org.br" },
    { "name": "SEMAS-PA",     "roles": ["funder"],               "url": "https://www.semas.pa.gov.br" }
  ],
  "extent": {
    "spatial": { "bbox": [[ -58.91, -9.84, -46.02, 2.59 ]] },
    "temporal": { "interval": [[ "2002-01-01T00:00:00Z", "2023-12-31T23:59:59Z" ]] }
  },
  "summaries": {
    "gsd": [1000],
    "proj:epsg": [4674],
    "version": ["1.0"],
    "ybyra:model": "Random Forest",
    "ybyra:auc_roc": 0.933,
    "ybyra:input_features": [
      "ERA5-Land (temperature, precipitation, VPD, wind)",
      "MapBiomas LULC (Col 10.1)",
      "MODIS/VIIRS active fire counts (2002–2023)",
      "landscape metrics (edge density, fragment count, ENN)",
      "secondary forest age"
    ],
    "ybyra:scale_factor": 10000,
    "ybyra:units": "probability [0–1] × 10000 stored as uint16"
  },
